   "outputs": [],
   "source": [
    "from transformers import pipeline\n",
    "\n",
    "# 感情分析パイプラインを読み込む（初回はモデルをダウンロード）\n",
    "classifier = pipeline(\"sentiment-analysis\")\n",
    "\n",
    "# 推論したいテキスト\n",
    "text = \"I love this beautiful day!\"\n",
    "\n",
    "# 推論実行\n",
    "result = classifier(text)\n",
    "\n",
    "print(result)\n"
   ]
  }
